---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import workspaceImage from '~/assets/images/yidianhub-workspace-v2.jpg';

const metadata = {
  title: 'YidianHub',
  description: '服务入口、文章与实用资源的独立空间。',
  ignoreTitleTemplate: true,
};

const latestWriting = [
  {
    date: '2026/07/17',
    title: '欢迎来到 YidianHub 文章',
    excerpt: 'YidianHub 文章站正式启用，记录服务说明、工具整理与持续更新的内容。',
    href: 'https://articles.yidianhub.com/posts/welcome/',
    meta: '站点动态',
  },
  {
    date: '持续更新',
    title: '服务说明与使用记录',
    excerpt: '围绕实际使用场景，整理稳定、清楚且可回看的服务信息。',
    href: 'https://articles.yidianhub.com',
    meta: '即将发布',
  },
  {
    date: '持续更新',
    title: '工具、资源与工作流',
    excerpt: '把日常使用中值得留下的工具、方法与链接集中到一个地方。',
    href: 'https://articles.yidianhub.com',
    meta: '即将发布',
  },
];

const routes = [
  {
    icon: 'tabler:server',
    title: 'API 服务',
    detail: '进入已部署的中转服务，开始处理实际任务。',
    href: 'https://api.yidianhub.com',
    external: true,
  },
  {
    icon: 'tabler:book-2',
    title: '文章空间',
    detail: '阅读服务说明、项目记录和持续整理的内容。',
    href: 'https://articles.yidianhub.com',
    external: true,
  },
  {
    icon: 'tabler:folder',
    title: '资源与工具',
    detail: '逐步沉淀常用工具、链接与实用方法。',
    href: '#process',
    external: false,
  },
  {
    icon: 'tabler:info-circle',
    title: '关于 YidianHub',
    detail: '了解本站的定位、入口边界与更新方向。',
    href: '#about',
    external: false,
  },
];
---

<Layout metadata={metadata}>
  <section class="relative isolate min-h-[44rem] overflow-hidden border-b border-white/10 bg-[#151714]">
    <Image
      src={workspaceImage}
      alt="夜间工作台上的笔记本电脑与台灯"
      class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
      widths={[960, 1440, 1800]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 -z-10 bg-black/55"></div>
    <div class="mx-auto flex min-h-[44rem] max-w-7xl items-end px-6 pb-14 pt-36 sm:pb-18 lg:px-8 lg:pb-24">
      <div class="max-w-2xl">
        <p class="mb-6 flex items-center gap-3 text-sm font-semibold text-primary">
          <span class="h-px w-10 bg-primary"></span>
          服务入口 · 长文阅读 · 资源沉淀
        </p>
        <h1 class="font-heading text-[2.4rem] font-bold leading-[1.13] text-white sm:text-6xl lg:text-7xl">
          让需要抵达的，<br />稳定地抵达。
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-8 text-[#d8ded5]">
          YidianHub 将服务、文章与日常资源放在同一条清晰路径上。没有多余干扰，打开后直接抵达正在需要的内容。
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            class="btn-primary gap-2"
            href="https://api.yidianhub.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="tabler:server" class="h-5 w-5" />
            进入 API 服务
          </a>
          <a
            class="btn-secondary gap-2 border-white/35 bg-black/20 hover:bg-white/10"
            href="https://articles.yidianhub.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="tabler:book-2" class="h-5 w-5" />
            浏览全部文章
          </a>
        </div>
        <dl class="mt-12 grid max-w-lg grid-cols-3 divide-x divide-white/20 border-t border-white/20 pt-6">
          <div class="pr-5">
            <dt class="text-2xl font-bold text-white">01</dt>
            <dd class="mt-1 text-sm text-[#b8c1b7]">服务入口</dd>
          </div>
          <div class="px-5">
            <dt class="text-2xl font-bold text-white">02</dt>
            <dd class="mt-1 text-sm text-[#b8c1b7]">内容空间</dd>
          </div>
          <div class="pl-5">
            <dt class="text-2xl font-bold text-white">03</dt>
            <dd class="mt-1 text-sm text-[#b8c1b7]">持续整理</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="border-b border-white/10 bg-[#181b18] py-18 sm:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col justify-between gap-5 border-b border-white/10 pb-8 sm:flex-row sm:items-end">
        <div>
          <p class="text-sm font-semibold text-primary">Latest writing</p>
          <h2 class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl">最近发布</h2>
        </div>
        <a
          class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-white"
          href="https://articles.yidianhub.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          查看全部文章
          <Icon name="tabler:arrow-up-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="grid divide-y divide-white/10 md:grid-cols-3 md:divide-x md:divide-y-0">
        {
          latestWriting.map((post, index) => (
            <article class:list={['py-8 md:py-10', { 'md:px-8': index > 0, 'md:pr-8': index === 0 }]}>
              <a
                class="group block"
                href={post.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={'阅读 ' + post.title}
              >
                <div class="flex items-center justify-between text-sm text-[#aab5aa]">
                  <span class="font-semibold text-primary">{post.meta}</span>
                  <time>{post.date}</time>
                </div>
                <h3 class="mt-7 font-heading text-2xl font-bold leading-snug text-white group-hover:text-primary">
                  {post.title}
                </h3>
                <p class="mt-4 leading-7 text-[#b8c1b7]">{post.excerpt}</p>
                <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-white group-hover:text-primary">
                  继续阅读
                  <Icon name="tabler:arrow-up-right" class="h-4 w-4" />
                </span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-[#151714] py-18 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
      <div>
        <p class="text-sm font-semibold text-primary">Explore YidianHub</p>
        <h2 class="mt-3 max-w-sm font-heading text-3xl font-bold leading-tight text-white sm:text-4xl">从你关心的事情开始</h2>
        <p class="mt-5 max-w-sm leading-7 text-[#b8c1b7]">
          入口不需要复杂。每一条路径都有明确去处，让服务、阅读和信息保持各自清楚。
        </p>
      </div>
      <div class="border-t border-white/10">
        {
          routes.map((route) => (
            <a
              class="group grid grid-cols-[2.75rem_1fr_auto] items-center gap-4 border-b border-white/10 py-6 transition hover:bg-white/[0.03] sm:grid-cols-[3.5rem_1fr_auto] sm:px-3"
              href={route.href}
              {...(route.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="grid h-10 w-10 place-items-center border border-white/15 text-primary">
                <Icon name={route.icon} class="h-5 w-5" />
              </span>
              <span>
                <strong class="block text-lg text-white">{route.title}</strong>
                <small class="mt-1 block text-sm leading-6 text-[#aab5aa]">{route.detail}</small>
              </span>
              <Icon
                name={route.external ? 'tabler:arrow-up-right' : 'tabler:chevron-right'}
                class="h-5 w-5 text-[#7d8a7d] transition group-hover:text-primary"
              />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="process" class="border-y border-white/10 bg-[#1b1f1b] py-18 sm:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid gap-10 border-b border-white/10 pb-10 lg:grid-cols-[0.85fr_1.15fr]">
        <div>
          <p class="text-sm font-semibold text-primary">Working flow</p>
          <h2 class="mt-3 font-heading text-3xl font-bold leading-tight text-white sm:text-4xl">服务、记录与阅读，形成一条稳定路径</h2>
        </div>
        <p class="max-w-2xl self-end leading-8 text-[#b8c1b7]">
          先让服务入口保持直接，再让需要留下的经验进入文章空间。工具与资源会随着实际使用逐步归档，而不是堆成难以查找的信息流。
        </p>
      </div>
      <ol class="grid gap-10 pt-10 md:grid-cols-3">
        <li>
          <span class="text-sm font-semibold text-[#d98256]">01</span>
          <h3 class="mt-4 text-xl font-bold text-white">直接进入服务</h3>
          <p class="mt-3 leading-7 text-[#aab5aa]">在需要时直接打开 API 服务，不增加额外跳转和干扰。</p>
        </li>
        <li>
          <span class="text-sm font-semibold text-[#d98256]">02</span>
          <h3 class="mt-4 text-xl font-bold text-white">沉淀必要记录</h3>
          <p class="mt-3 leading-7 text-[#aab5aa]">将说明、方法与更新写成可长期回看的文章。</p>
        </li>
        <li>
          <span class="text-sm font-semibold text-[#d98256]">03</span>
          <h3 class="mt-4 text-xl font-bold text-white">持续整理资源</h3>
          <p class="mt-3 leading-7 text-[#aab5aa]">只保留真正有用的工具和链接，让入口保持轻量。</p>
        </li>
      </ol>
    </div>
  </section>

  <section id="about" class="bg-[#151714] py-16 sm:py-20">
    <div class="mx-auto flex max-w-7xl flex-col justify-between gap-8 px-6 sm:flex-row sm:items-end lg:px-8">
      <div>
        <p class="text-sm font-semibold text-primary">About</p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-white">让内容先被找到，让服务直接可用。</h2>
      </div>
      <a
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-white"
        href="https://articles.yidianhub.com/about/"
        target="_blank"
        rel="noopener noreferrer"
      >
        了解文章空间
        <Icon name="tabler:arrow-up-right" class="h-4 w-4" />
      </a>
    </div>
  </section>
</Layout>
