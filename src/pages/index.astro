---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import heroImage from '~/assets/images/hero-image.png';

const metadata = {
  title: 'YidianHub',
  description: '服务、文章与实用资源的统一入口。',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="border-b border-black/8 bg-[#f7f8f6] dark:border-white/10 dark:bg-[#111513]">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 sm:py-20 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-16 lg:px-8 lg:py-24">
      <div class="max-w-2xl">
        <p class="mb-6 flex items-center gap-3 text-sm font-semibold text-[#0b786d] dark:text-[#61d7c8]">
          <span class="h-px w-10 bg-current"></span>
          YIDIANHUB
        </p>
        <h1 class="max-w-xl text-4xl font-bold leading-[1.12] tracking-normal text-[#16191b] dark:text-white sm:text-5xl lg:text-6xl">
          把服务、内容与信息，放在同一入口。
        </h1>
        <p class="mt-7 max-w-xl text-lg leading-8 text-[#5b625f] dark:text-[#b9c4be]">
          YidianHub 为日常使用提供清晰的服务入口、持续更新的文章与实用资源。访问路径保持简单，内容各归其位。
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            class="btn-primary inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 font-semibold"
            href="https://api.yidianhub.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            进入 API 服务
            <Icon name="tabler:arrow-up-right" class="h-5 w-5" />
          </a>
          <a
            class="btn-secondary inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 font-semibold"
            href="https://articles.yidianhub.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            阅读文章
            <Icon name="tabler:book-2" class="h-5 w-5" />
          </a>
        </div>
        <dl class="mt-12 grid max-w-lg grid-cols-3 gap-5 border-t border-black/10 pt-6 dark:border-white/10">
          <div>
            <dt class="text-2xl font-bold text-[#16191b] dark:text-white">01</dt>
            <dd class="mt-1 text-sm text-[#69726d] dark:text-[#aebbb4]">服务入口</dd>
          </div>
          <div>
            <dt class="text-2xl font-bold text-[#16191b] dark:text-white">02</dt>
            <dd class="mt-1 text-sm text-[#69726d] dark:text-[#aebbb4]">内容空间</dd>
          </div>
          <div>
            <dt class="text-2xl font-bold text-[#16191b] dark:text-white">03</dt>
            <dd class="mt-1 text-sm text-[#69726d] dark:text-[#aebbb4]">持续整理</dd>
          </div>
        </dl>
      </div>

      <div class="relative mx-auto w-full max-w-xl">
        <div class="absolute -left-3 -top-3 h-24 w-24 border-l-2 border-t-2 border-[#e06c3d]"></div>
        <div class="relative overflow-hidden border border-black/10 bg-[#e7efec] p-6 dark:border-white/10 dark:bg-[#17211e] sm:p-9">
          <Image
            src={heroImage}
            alt="代表 YidianHub 服务连接与信息流动的抽象视觉"
            class="h-auto w-full object-contain"
            widths={[640, 960]}
            sizes="(min-width: 1024px) 42vw, 88vw"
            loading="eager"
            fetchpriority="high"
          />
          <div class="mt-3 flex items-center justify-between border-t border-black/10 pt-4 text-sm dark:border-white/10">
            <span class="font-semibold text-[#16191b] dark:text-white">YidianHub</span>
            <span class="text-[#55706a] dark:text-[#a7c6bd]">Services · Articles · Resources</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="resources" class="bg-white py-16 dark:bg-[#0e1110] sm:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col justify-between gap-5 border-b border-black/10 pb-8 dark:border-white/10 sm:flex-row sm:items-end">
        <div>
          <p class="text-sm font-semibold text-[#0b786d] dark:text-[#61d7c8]">EXPLORE</p>
          <h2 class="mt-3 text-3xl font-bold text-[#16191b] dark:text-white sm:text-4xl">从你要做的事情开始</h2>
        </div>
        <p class="max-w-md text-base leading-7 text-[#66706b] dark:text-[#aebbb4]">
          每个入口只承担一件明确的事，减少在不同服务之间来回寻找的时间。
        </p>
      </div>

      <div class="grid gap-px bg-black/10 pt-8 dark:bg-white/10 md:grid-cols-3">
        <a
          class="group bg-white p-7 transition hover:bg-[#eef7f4] dark:bg-[#0e1110] dark:hover:bg-[#17211e]"
          href="https://api.yidianhub.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="tabler:arrows-exchange-2" class="h-7 w-7 text-[#0b9d8c]" />
          <h3 class="mt-8 text-xl font-bold text-[#16191b] dark:text-white">API 服务</h3>
          <p class="mt-3 leading-7 text-[#66706b] dark:text-[#aebbb4]">进入已部署的服务中转站，开始处理实际任务。</p>
          <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-[#0b786d] dark:text-[#61d7c8]">
            打开服务 <Icon name="tabler:arrow-up-right" class="h-4 w-4" />
          </span>
        </a>
        <a
          class="group bg-white p-7 transition hover:bg-[#fff4ec] dark:bg-[#0e1110] dark:hover:bg-[#241915]"
          href="https://articles.yidianhub.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="tabler:notebook" class="h-7 w-7 text-[#e06c3d]" />
          <h3 class="mt-8 text-xl font-bold text-[#16191b] dark:text-white">文章空间</h3>
          <p class="mt-3 leading-7 text-[#66706b] dark:text-[#aebbb4]">阅读项目记录、使用说明和持续更新的内容。</p>
          <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-[#b14f29] dark:text-[#ffb08d]">
            浏览文章 <Icon name="tabler:arrow-up-right" class="h-4 w-4" />
          </span>
        </a>
        <a class="group bg-white p-7 transition hover:bg-[#f5f5f2] dark:bg-[#0e1110] dark:hover:bg-[#171917]" href="#about">
          <Icon name="tabler:tool" class="h-7 w-7 text-[#62706b] dark:text-[#c5d0ca]" />
          <h3 class="mt-8 text-xl font-bold text-[#16191b] dark:text-white">资源与工具</h3>
          <p class="mt-3 leading-7 text-[#66706b] dark:text-[#aebbb4]">将逐步整理高频使用的工具、链接和相关信息。</p>
          <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-[#44504b] dark:text-[#c5d0ca]">
            查看说明 <Icon name="tabler:arrow-down" class="h-4 w-4" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <section id="about" class="border-y border-black/10 bg-[#f7f8f6] py-16 dark:border-white/10 dark:bg-[#111513] sm:py-20">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
      <div>
        <p class="text-sm font-semibold text-[#0b786d] dark:text-[#61d7c8]">ABOUT</p>
        <h2 class="mt-3 text-3xl font-bold text-[#16191b] dark:text-white sm:text-4xl">让路径保持清楚</h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-3">
        <div>
          <p class="text-sm font-semibold text-[#e06c3d]">01</p>
          <h3 class="mt-3 text-lg font-bold text-[#16191b] dark:text-white">明确入口</h3>
          <p class="mt-2 text-sm leading-6 text-[#66706b] dark:text-[#aebbb4]">服务、文章和资源从首页直接抵达。</p>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#e06c3d]">02</p>
          <h3 class="mt-3 text-lg font-bold text-[#16191b] dark:text-white">稳定内容</h3>
          <p class="mt-2 text-sm leading-6 text-[#66706b] dark:text-[#aebbb4]">文章在独立站点长期保留，便于阅读和分享。</p>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#e06c3d]">03</p>
          <h3 class="mt-3 text-lg font-bold text-[#16191b] dark:text-white">持续迭代</h3>
          <p class="mt-2 text-sm leading-6 text-[#66706b] dark:text-[#aebbb4]">先交付核心路径，再根据实际使用扩展功能。</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
