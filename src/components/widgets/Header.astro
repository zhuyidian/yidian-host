---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash, getAsset } from '~/utils/permalinks';
import type { CallToAction } from '~/types';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
  target?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  actions?: Array<CallToAction>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  showToggleTheme = false,
  showRssFeed = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 mx-auto h-[61px] w-full flex-none border-b border-[var(--yidian-header-border)] bg-[var(--yidian-header)] backdrop-blur-md transition-[opacity] ease-in-out md:h-[69px]',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div class="absolute inset-0"></div>
  <div
    class:list={[
      'relative mx-auto h-[60px] w-full max-w-[1180px] px-[20px] text-default md:h-[68px] md:px-0',
      {
        'md:flex md:justify-between': position !== 'center',
      },
      {
        'md:grid md:grid-cols-[auto_1fr_auto] md:items-center md:gap-[28px]': position === 'center',
      },
      {
        'max-w-[1180px]': !isFullWidth,
      },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo tagline="让内容先被找到，让服务直接可用" />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="hidden w-full items-center overflow-y-auto overflow-x-hidden text-default md:flex md:h-[36px] md:justify-center md:justify-self-center md:overflow-visible"
      aria-label="Main navigation"
    >
      <ul
        class="flex w-full flex-col text-xl font-semibold tracking-normal md:w-auto md:flex-row md:justify-center md:gap-[4px] md:self-center md:text-[14px] md:font-[650]"
      >
        {
          links.map(({ text, href, links, target }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button
                    type="button"
                    class="hover:text-link dark:hover:text-white px-4 py-3 flex items-center whitespace-nowrap"
                  >
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                  </button>
                  <ul class="dropdown-menu md:backdrop-blur-md dark:md:bg-dark rounded md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white/90 md:min-w-[200px] drop-shadow-xl">
                    {links.map(({ text: text2, href: href2 }) => (
                      <li>
                        <a
                          class:list={[
                            'first:rounded-t last:rounded-b md:hover:bg-gray-100 hover:text-link dark:hover:text-white dark:hover:bg-gray-700 py-2 px-5 block whitespace-no-wrap',
                            { 'aw-link-active': href2 === currentPath },
                          ]}
                          href={href2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class:list={[
                    'relative flex items-center whitespace-nowrap px-[12px] py-3 text-[var(--yidian-nav-muted)] transition-colors hover:text-[var(--yidian-nav-active)] after:absolute after:bottom-[2px] after:left-[12px] after:hidden after:h-[2px] after:w-[28px] after:scale-x-0 after:bg-[#71d7a7] after:transition-transform md:py-[8px] md:leading-[20px] md:after:block',
                    { 'is-active': href === currentPath },
                  ]}
                  data-aw-nav-link
                  href={href}
                  {...(target ? { target: target, rel: 'noopener noreferrer' } : {})}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        'hidden md:self-center md:flex items-center md:mb-0 fixed w-full md:w-auto md:static justify-end left-0 rtl:left-auto rtl:right-0 bottom-0 p-3 md:p-0 md:justify-self-end',
      ]}
    >
      <div class="flex w-full items-center justify-between md:w-auto md:justify-end">
        <div class="flex items-center gap-[13px]">
          <span class="inline-flex min-w-[62px] items-center gap-[7px] whitespace-nowrap text-[12px] font-normal leading-[15px] text-[var(--yidian-brand-muted)]" role="status">
            <span class="h-[7px] w-[7px] rounded-full bg-[#71d7a7] shadow-[0_0_0_3px_rgb(113_215_167_/_0.12)]"></span>
            服务正常
          </span>
          {
            showToggleTheme && (
              <ToggleTheme
                class="grid h-[34px] w-[34px] place-items-center rounded-[8px] border border-[var(--yidian-toggle-border)] bg-[var(--yidian-toggle-bg)] text-[var(--yidian-nav-active)] transition hover:border-[#71d7a7] focus:outline-none focus:ring-2 focus:ring-[#71d7a7]/40"
                iconClass="h-[18px] w-[18px]"
              />
            )
          }
          {
            showRssFeed && (
              <a
                class="text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center"
                aria-label="RSS Feed"
                href={getAsset('/rss.xml')}
              >
                <Icon name="tabler:rss" class="w-5 h-5" />
              </a>
            )
          }
        </div>
        {
          actions?.length ? (
            <span class="ml-4 rtl:ml-0 rtl:mr-4">
              {actions.map((btnProps) => (
                <Button {...btnProps} class="ml-2 py-2.5 px-5.5 md:px-6 font-semibold shadow-none text-sm w-auto" />
              ))}
            </span>
          ) : (
            ''
          )
        }
      </div>
    </div>
  </div>
</header>

<script is:inline>
  function setActiveHeaderLink(activeLink) {
    const links = document.querySelectorAll('#header [data-aw-nav-link]');

    links.forEach((link) => {
      const isActive = link === activeLink;
      link.classList.toggle('is-active', isActive);

      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  function syncHeaderNavigation() {
    const links = Array.from(document.querySelectorAll('#header [data-aw-nav-link]'));
    if (!links.length) return;

    const matchingLink = links.find((link) => {
      const url = new URL(link.getAttribute('href'), window.location.href);
      if (url.origin !== window.location.origin || url.pathname !== window.location.pathname) return false;

      return window.location.hash ? url.hash === window.location.hash : !url.hash;
    });

    setActiveHeaderLink(matchingLink || links[0]);

    links.forEach((link) => {
      if (link.dataset.awNavBound) return;
      link.dataset.awNavBound = 'true';
      link.addEventListener('click', () => setActiveHeaderLink(link));
    });
  }

  syncHeaderNavigation();
  window.addEventListener('hashchange', syncHeaderNavigation);
  document.addEventListener('astro:page-load', syncHeaderNavigation);
</script>
