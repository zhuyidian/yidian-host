---
import Logo from '~/components/Logo.astro';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { links = [] } = Astro.props;
const footerLinks = links.flatMap((group) => group.links);
---

<footer id="about" class="yidian-footer relative min-h-[150px] bg-[var(--yidian-footer-bg)] text-[#dfe4dd] not-prose">
  <div class="mx-auto grid min-h-[150px] w-full max-w-[1180px] items-center gap-[24px] px-[20px] py-[32px] md:grid-cols-[auto_1fr_auto] md:gap-[40px] md:px-0 md:py-0">
    <a class="flex items-center" href={getHomePermalink()} aria-label="YidianHub 首页">
      <Logo />
    </a>

    <p class="m-0 text-[13px] font-normal leading-[16px] text-[#8f998d]">
      服务、文章与日常资源的独立空间。
    </p>

    <nav class="flex flex-wrap items-center gap-x-[18px] gap-y-[8px] text-[13px] font-normal leading-[16px]" aria-label="页脚导航">
      {
        footerLinks.map(({ text, href, ariaLabel }) => (
          <a
            class="whitespace-nowrap text-[#aeb7ac] transition-colors hover:text-[#dfe4dd]"
            href={href}
            aria-label={ariaLabel}
            {...(href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <Fragment set:html={text} />
          </a>
        ))
      }
    </nav>
  </div>
</footer>
